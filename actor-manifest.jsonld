source:'resource:mountain-pass', target:'operator:mp-materials', relation:'supplies', kind:'resource_flow', status:'active', priority:1},\n  {id:'dod-finances-mp', source:'financer:us-dod-osc', target:'operator:mp-materials', relation:'finances', kind:'capital_flow', status:'active', priority:1},\n  {id:'mp-supplies-texas-plant', source:'operator:mp-materials', target:'plant:mp-independence-texas', relation:'supplies', kind:'resource_flow', status:'active', priority:1},\n  {id:'texas-plant-supplies-gm', source:'plant:mp-independence-texas', target:'oem:general-motors', relation:'supplies', kind:'offtake', status:'active', priority:1},\n  {id:'reelement-supplies-urban-mining', source:'processor:reelement-technologies', target:'recycling:urban-mining-company', relation:'supplies', kind:'resource_flow', status:'active', priority:2},\n  {id:'urban-mining-supplies-defense', source:'recycling:urban-mining-company', target:'sector:global-defense-oem', relation:'supplies', kind:'resource_flow', status:'active', priority:2},\n  {id:'arnold-supplies-defense', source:'magnet:arnold-magnetic', target:'sector:global-defense-oem', relation:'supplies', kind:'resource_flow', status:'active', priority:2},\n  {id:'mp-supplies-defense', source:'operator:mp-materials', target:'sector:global-defense-oem', relation:'supplies', kind:'resource_flow', status:'active', priority:1},\n  {id:'mt-weld-supplies-lynas-malaysia', source:'resource:mt-weld', target:'plant:lynas-malaysia', relation:'supplies', kind:'resource_flow', status:'active', priority:1},\n  {id:'sojitz-supports-lynas', source:'trader:sojitz', target:'operator:lynas-rare-earths', relation:'supports', kind:'capital_flow', status:'active', priority:2},\n  {id:'lynas-malaysia-supplies-proterial', source:'plant:lynas-malaysia', target:'magnet:proterial', relation:'supplies', kind:'resource_flow', status:'active', priority:2},\n  {id:'lynas-malaysia-supplies-neo', source:'plant:lynas-malaysia', target:'processor:neo-performance-mater