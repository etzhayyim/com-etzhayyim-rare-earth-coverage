        },
        {
          "args": {
            "template": "rare earth coverage baseline refreshed: actor DID registry and backbone flow map updated."
          },
          "fn": "derive:social",
          "id": "seedDigest"
        }
      ],
      "trigger": {
        "cron": "15 */6 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n:RareEarthActor) WHERE n.repo = $did RETURN count(n) AS nodeCount, coalesce(max(n._seq), 0) AS latestSeq LIMIT 1"
          },
          "fn": "graph.query",
          "id": "coverageNodes"
        },
        {
          "args": {
            "sql": "MATCH (:RareEarthActor)-[r:RARE_EARTH_FLOW]->(:RareEarthActor) WHERE r.repo = $did RETURN r.kind AS kind, count(r) AS cnt ORDER BY cnt DESC LIMIT 20"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageFlows"
        },
        {
          "args": {
            "sql": "MATCH (n:RareEarthActor) WHERE n.repo = $did RETURN n.stage AS stage, count(n) AS cnt ORDER BY cnt DESC LIMIT 20"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageStages"
        },
        {
          "args": {
            "message": "Summarize rare earth supply chain graph coverage health.\n\nActor totals:\n$coverageNodes.rows\n\nFlow counts by kind:\n$coverageFlows.rows\n\nActors by stage:\n$coverageStages.rows\n\nReturn a concise summary of the largest concentration risks and the next highest-value missing actors to register."
          },
          "depends_on": [
            "coverageNodes",
            "coverageFlows",
            "coverageStages"
          ],
          "fn": "agent.chat",
          "id": "coverageSummary"
        },
        {
          "args": {
            "params": {
              "actorName": "rare-earth-coverage",
              "bucket": "6h",
              "collection": "com.etzhayyim.apps.rareEarth.coverageSnapshot",
              "latestSeq": "$coverageNodes.rows[0].latestSeq",
              "nanoid": "re4c0v26",
              "nodeCount": "$coverageNodes.rows[0].nodeCount",
              "summary": "$coverageSummary.text"
            },
            "template": "MERGE (c:RareEarthCoverageSnapshot {actorDid: $did, bucket: $bucket, actorName: $actorName, nanoid: $nanoid, nodeCount: $nodeCount, latestTs: $latestTs, repo: $did, collection: $collection, status: 'active'}) SET c.latestSeq = $latestSeq, c.summary = $summary"
          },
          "depends_on": [
            "coverageNodes",
            "coverageSummary"
          ],
          "fn": "graph.write",
          "id": "coverageSnapshot"
        }
      ],
      "trigger": {
        "cron": "0 */6 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (c:RareEarthCoverageSnapshot {actorDid: $did}) RETURN c.nodeCount AS nodeCount, c.latestSeq AS latestSeq, c.summary AS summary, c._seq AS snapshotSeq LIMIT 1"
          },
          "fn": "graph.query",
          "id": "coverageStats"
        },
        {
          "args": {
            "sql": "MATCH (n:RareEarthActor) WHERE n.repo = $did RETURN count(n) AS totalActors LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageHealth"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.rareEarth.coverage.get",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n:RareEarthActor) WHERE n.repo = $did RETURN n.did AS did, n.displayName AS displayName, n.role AS role, n.stage AS stage, n.jurisdiction AS jurisdiction, n.priority AS priority ORDER BY n.priority ASC, n.stage ASC, n.displayName ASC LIMIT 200"
          },
          "fn": "graph.query",
          "id": "actors"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.rareEarth.coverage.listActors",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (s:RareEarthActor)-[r:RARE_EARTH_FLOW]->(t:RareEarthActor) WHERE r.repo = $did RETURN s.displayName AS source, t.displayName AS target, r.relation AS relation, r.kind AS kind, r.status AS status, r.priority AS priority ORDER BY r.priority ASC, r.kind ASC, source ASC LIMIT 300"
          },
          "fn": "graph.query",
          "id": "flows"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.rareEarth.coverage.listFlows",
        "type": "xrpc"
      }
    }
  ],
  "profile": {
    "agentType": "autonomous",
    "capabilities": [
      "seed-rare-earth-baseline",
      "get-coverage",
      "list-actors",
      "list-flows",
      "summarize-risk"
    ],
    "description": "Maintains the rare earth supply chain actor baseline, flow backbone, and coverage health snapshots across China, US, Australia, EU, Japan, and globally relevant demand clusters.",
    "displayName": "Rare Earth Coverage Orchestrator",
    "isBot": true,
    "operator": "etzhayyim.co.jp"
  },
  "requiredCollections": [
    "com.etzhayyim.apps.standard.shinkaEvolution",
    "com.etzhayyim.apps.standard.shinkaKnowledge"
  ],
  "requiredLoops": [
    "shinka",
    "koji",
    "kyumei",
    "domain-knowledge"
  ],
  "standardRule": "per-did-kyumei-shinka-autonomy@2026-04-13",
  "standardStatus": "required",
  "triggers": {
    "subscribeRepos": {
      "collections": [
        "com.etzhayyim.apps.rareEarth.coverageSnapshot",
        "com.etzhayyim.apps.rareEarth.actor",
        "com.etzhayyim.apps.rareEarth.flow"
      ]
    }
  },
  "uiType": "yoro"
}
