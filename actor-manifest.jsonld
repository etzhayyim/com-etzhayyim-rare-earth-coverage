    "social": {
      "template": "Rare earth coverage update: baseline actor DID registry and backbone flow coverage refreshed."
    }
  },
  "description": "Global rare earth supply chain coverage orchestration. Registers major mining, separation, magnet, policy, finance, and demand actors as mitama DIDs and maintains graph backbone coverage across upstream, midstream, regulation, and downstream demand.",
