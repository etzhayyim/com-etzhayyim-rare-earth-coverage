nse', source:'plant:eneabba-refinery', target:'sector:global-defense-oem', relation:'intended-to-supply', kind:'resource_flow', status:'planned', priority:2},\n  {id:'eu-council-mandates-commission', source:'regulator:eu-council', target:'regulator:eu-commission', relation:'mandates', kind:'policy', status:'active', priority:2},\n  {id:'eu-commission-chairs-board', source:'regulator:eu-commission', target:'governance:eu-crm-board', relation:'chairs', kind:'governance', status:'active', priority:2},\n  {id:'eu-commission-enables-caremag', source:'regulator:eu-commission', target:'operator:caremag', relation:'enables', kind:'policy', status:'active', priority:2},\n  {id:'solvay-supplies-vac', source:'processor:solvay', target:'magnet:vacuumschmelze', relation:'supplies', kind:'resource_flow', status:'active', priority:2},\n  {id:'meti-directs-jogmec', source:'regulator:meti', target:'financer:jogmec', relation:'directs', kind:'policy', status:'active', priority:1},\n  {id:'jogmec-finances-caremag', source:'financer:jogmec', target:'operator:caremag', relation:'finances', kind:'capital_flow', status:'active', priority:1},\n  {id:'caremag-intends-defense', source:'operator:caremag', target:'sector:global-defense-oem', relation:'intended-to-supply', kind:'resource_flow', status:'planned', priority:2},\n  {id:'caremag-intends-ev', source:'operator:caremag', target:'sector:global-ev-oem', relation:'intended-to-supply', kind:'resource_flow', status:'planned', priority:2}\n] AS e MATCH (s:RareEarthActor {did: 'did:web:rare-earth-coverage.etzhayyim.com:' + e.source}) MATCH (t:RareEarthActor {did: 'did:web:rare-earth-coverage.etzhayyim.com:' + e.target}) MERGE (s)-[r:RARE_EARTH_FLOW {flowKey: e.id}]->(t) SET r.relation = e.relation, r.kind = e.kind, r.status = e.status, r.priority = e.priority, r.repo = 'did:web:rare-earth-coverage.etzhayyim.com', r.collection = 'com.etzhayyim.apps.rareEarth.flow'"
          },
          "fn": "graph.write",
